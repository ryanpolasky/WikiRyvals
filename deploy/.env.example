# WikiRyvals backend configuration - copy to `.env` next to docker-compose.yml.
# Every value has a safe default; you really only need the SMTP_* block for prod.

# ---- Networking -------------------------------------------------------------
# Host port the container's :8011 is published on. Drop this (and the compose
# `ports:` block) if you front the service with your own reverse proxy.
WIKIRYVALS_PORT=8011

# ---- Durable state ----------------------------------------------------------
# These default to /app/pgdata inside the image (mounted on the named volume).
# Only override if you mount the volume somewhere else.
WIKIRYVALS_PLAY_GRAPH=/app/pgdata/play_graph.sqlite3
WIKIRYVALS_ACCOUNTS=/app/pgdata/accounts.sqlite3

# ---- Email (login codes) ----------------------------------------------------
# Auth is passwordless: email -> 6-digit code -> session token.
#
# IMPORTANT: if WIKIRYVALS_SMTP_HOST is EMPTY the backend runs in dev-auth mode -
# it logs the code AND returns it in the API response (`dev_code`). That is fine
# for local dev but MUST NOT be used in production. Set SMTP_HOST to a real host
# and the dev_code leak is disabled automatically; codes are emailed instead.
WIKIRYVALS_SMTP_HOST=
WIKIRYVALS_SMTP_PORT=587
WIKIRYVALS_SMTP_USER=
WIKIRYVALS_SMTP_PASS=
WIKIRYVALS_SMTP_FROM=no-reply@wikiryvals.com
